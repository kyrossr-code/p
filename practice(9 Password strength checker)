while True:
    password_strength = 0
    Password = input("Enter a password and check its strength: ")
    if len(Password) >= 8:
        password_strength += 1
    if any(char.isupper() for char in Password):
        password_strength += 1
    if any(char.isnumeric() for char in Password):
        password_strength += 1
    if any(char in "!@#$%^&*()-_=+[]{}|;:'\",.<>?/" for char in Password):
        password_strength += 1
        
    if password_strength == 0:
        print("Password is very weak.")
    elif password_strength == 1:
        print("Password is weak.")
    elif password_strength == 2:
        print("Password is moderate.")
    elif password_strength == 3:
        print("Password is strong.")
    elif password_strength == 4:
        print("Password is very strong.")

    while True:    
        answer = input("Password strength checked, would you like to check another password? (yes/no) ").strip().lower()
        if answer == "yes":
            break
        elif answer == "no":
            print("Goodbye!")
            raise SystemExit
        else:
            print("Invalid input. Please enter 'yes' or 'no'.")

        